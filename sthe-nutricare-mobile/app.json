{
  "expo": {
    "name": "sthe-nutricare-mobile",
    "slug": "sthe-nutricare-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_ss_ss.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_stheffane_santos_nutricionista.png",
      "resizeMode": "contain",
      "backgroundColor": "#EFEDE7"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_ss_ss.png",
        "backgroundColor": "#EFEDE7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo_ss_ss.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}