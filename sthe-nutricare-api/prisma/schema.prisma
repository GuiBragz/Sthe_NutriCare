generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                Int                 @id @default(autoincrement())
  nomeCompleto      String
  email             String              @unique
  senha             String
  tipo              TipoUsuario         @default(PACIENTE)
  telefone          String?
  fotoPerfilUrl     String?
  dataNascimento    String?
  sexo              String?
  altura            Float?
  objetivos         String?
  termosAceitos     Boolean             @default(true)
  dataCriacao       DateTime            @default(now())
  pushToken         String?

  agendamentos      Agendamento[]
  metas             MetaSaude?
  diarios           DiarioDiario[]
  planos            PlanoNutricional[]
  likesReceitas     ReceitaLike[]
  receitasFavoritas ReceitaFavorita[]
  comentarios       ComentarioReceita[]

  @@map("tb_usuarios")
}

model MetaSaude {
  id                 Int     @id @default(autoincrement())
  usuarioId          Int     @unique
  usuario            Usuario @relation(fields: [usuarioId], references: [id])
  pesoAtual          Float
  pesoMeta           Float
  metaCaloricaDiaria Int
  metaAguaDiaria     Int

  @@map("tb_metas_saude")
}

model Agendamento {
  id               Int               @id @default(autoincrement())
  usuarioId        Int?
  usuario          Usuario?          @relation(fields: [usuarioId], references: [id])
  formaPagamento   FormaPagamento?
  valorPago        Decimal?          @db.Decimal(10, 2)
  dataHoraConsulta DateTime
  status           StatusAgendamento @default(DISPONIVEL)
  observacoes      String?
  tipoConsulta     TipoConsulta      @default(PRESENCIAL)
  linkMeet         String?
  endereco         String?

  @@map("tb_agendamentos")
}

model PlanoNutricional {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  titulo     String
  arquivoUrl String?
  descricao  String?  @db.Text
  dataUpload DateTime @default(now())

  @@map("tb_planos_nutricionais")
}

model Receita {
  id             Int                 @id @default(autoincrement())
  titulo         String
  ingredientes   String              @db.Text
  modoPreparo    String              @db.Text
  caloriasTotais Int
  fotoUrl        String?
  categoria      String
  dataCriacao    DateTime            @default(now())

  comentarios    ComentarioReceita[]
  likes          ReceitaLike[]
  favoritos      ReceitaFavorita[]

  @@map("tb_receitas")
}

model ReceitaLike {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  receitaId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  receita   Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, receitaId])
  @@map("tb_receita_likes")
}

model ReceitaFavorita {
  id        Int     @id @default(autoincrement())
  usuarioId Int
  receitaId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  receita   Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, receitaId])
  @@map("tb_receita_favoritas")
}

model ComentarioReceita {
  id          Int      @id @default(autoincrement())
  texto       String   @db.Text
  dataCriacao DateTime @default(now())
  usuarioId   Int
  receitaId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  receita     Receita  @relation(fields: [receitaId], references: [id], onDelete: Cascade)

  @@map("tb_comentarios_receita")
}

model DiarioDiario {
  id                 Int        @id @default(autoincrement())
  usuarioId          Int
  usuario            Usuario    @relation(fields: [usuarioId], references: [id])
  dataRegistro       DateTime   @default(now())
  layoutUsado        TipoLayout @default(SIMPLES)
  pesoAtual          Float?
  caloriasConsumidas Int        @default(0)
  caloriasQueimadas  Int        @default(0)
  aguaConsumida      Int        @default(0)
  observacoesDia     String?    @db.Text

  refeicoes          Refeicao[]

  @@map("tb_diario_diario")
}

model Refeicao {
  id           Int          @id @default(autoincrement())
  diarioId     Int
  diario       DiarioDiario @relation(fields: [diarioId], references: [id], onDelete: Cascade)
  nome         String
  calorias     Int          @default(0)
  detalhes     String?      @db.Text
  proteinas    Float?
  carboidratos Float?
  gorduras     Float?

  @@map("tb_refeicoes")
}

enum TipoUsuario {
  ADMIN
  NUTRICIONISTA
  PACIENTE
}

enum FormaPagamento {
  PIX
  CARTAO
}

enum StatusAgendamento {
  DISPONIVEL
  AGUARDANDO_PAGAMENTO
  AGENDADO
  CONFIRMADO
  REALIZADO
  FALTOU
  CANCELADO_COM_CREDITO
  CANCELADO
}

enum TipoConsulta {
  ONLINE
  PRESENCIAL
}

enum TipoLayout {
  SIMPLES
  COMPLEXO
}